# Compass API Environment Variables

# Server Configuration
PORT=8000
HOST=0.0.0.0
COMPASS_CLOUD_MODE=false # Set to true to disable shell tool execution

# Database
# Default uses local SQLite if not provided.
# DB_URI=postgresql://user:pass@localhost:5432/compass

# OpenAI API (For core LLM agent capabilities)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic API (Alternative LLM)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Web Search Tool
TAVILY_API_KEY=your_tavily_api_key_here
